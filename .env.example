# ============================================================
# fileaway.app — Environment Variables
# Copy this file to .env.local and fill in all required values.
# Never commit .env.local to version control.
# ============================================================

# ---- Convex ------------------------------------------------
# Found in: Convex Dashboard → Settings → URL & Deploy Key
CONVEX_DEPLOYMENT=dev:your-project-name
NEXT_PUBLIC_CONVEX_URL=https://your-project-name.convex.cloud

# ---- Apify --------------------------------------------------
# Found in: https://console.apify.com/account/integrations
APIFY_API_TOKEN=your-apify-api-token

# Optional: override default actor IDs
# APIFY_ACTOR_TIKTOK=apidojo/tiktok-scraper
# APIFY_ACTOR_INSTAGRAM=apify/instagram-scraper

# ---- Google Gemini ------------------------------------------
# Found in: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ---- App Config ---------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
