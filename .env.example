# ============================================================
# fileaway.app — Environment Variables
# Copy this file to .env.local and fill in all required values.
# Never commit .env.local to version control.
# ============================================================

# ---- Supabase -----------------------------------------------
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct database connection string (for pg-boss job queue)
# Found in: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ---- Apify --------------------------------------------------
# Found in: https://console.apify.com/account/integrations
APIFY_API_TOKEN=your-apify-api-token

# ---- Google Gemini ------------------------------------------
# Found in: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ---- App Config ---------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
